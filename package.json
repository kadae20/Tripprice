{
  "name": "tripprice-editorial",
  "version": "1.0.0",
  "description": "Tripprice 편집국 자동화 스크립트",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "ingest": "node scripts/ingest-hotel-data.js",
    "publish": "node scripts/_run-with-env.js scripts/wp-publish.js",
    "pipeline": "node scripts/_run-with-env.js scripts/pipeline.js",
    "taxonomy": "node scripts/_run-with-env.js scripts/_fetch-wp-taxonomy.js",
    "images": "node scripts/process-images.js",
    "newsroom:daily": "node scripts/_run-with-env.js scripts/newsroom.js daily",
    "newsroom:monthly": "node scripts/_run-with-env.js scripts/newsroom.js monthly",
    "schedule:jobs": "node scripts/scheduler-generate-jobs.js",
    "report:download": "node scripts/_run-with-env.js scripts/agoda-report-download.js",
    "report:monthly": "node scripts/_run-with-env.js scripts/agoda-report-parse.js",
    "hoteldata:fetchurl": "node scripts/_run-with-env.js scripts/agoda-partner-fetch-url.js",
    "hoteldata:sync": "node scripts/_run-with-env.js scripts/agoda-hoteldata-sync.js",
    "hoteldata:dry": "node scripts/_run-with-env.js scripts/agoda-hoteldata-sync.js --dry-run",
    "hoteldata:extract": "node scripts/_run-with-env.js scripts/hoteldata-extract.js",
    "hoteldata:transform": "node scripts/_run-with-env.js scripts/hoteldata-to-tripprice.js",
    "hoteldata:ingest": "node scripts/_run-with-env.js scripts/ingest-hotel-data.js data/hotels/tripprice-hotels.csv",
    "data:download": "node scripts/_run-with-env.js scripts/agoda-hotel-data-download.js",
    "cost:fetch": "node scripts/_run-with-env.js scripts/aws-cost-fetch.js",
    "cost:update": "node scripts/_run-with-env.js scripts/aws-cost-fetch.js --update-env",
    "smoke:zai": "node scripts/_run-with-env.js scripts/_smoke-zai.js",
    "smoke:wp": "node scripts/_run-with-env.js scripts/_smoke-wp-post.js",
    "qa": "node scripts/qa-wp-post.js",
    "publish:auto": "node scripts/publish-auto.js",
    "editorial:os": "node scripts/editorial-os.js",
    "editorial:chief": "node scripts/editorial-chief.js --auto --since=$(date +%Y-%m-%d)",
    "editorial:run": "node scripts/editorial-chief.js --auto --since=$(date +%Y-%m-%d) --publish --max-publish=5",
    "smoke": "node scripts/_run-with-env.js scripts/_smoke-wp-post.js && node scripts/_run-with-env.js scripts/_smoke-zai.js",
    "24h": "node scripts/_run-with-env.js scripts/editorial-24h.js",
    "24h:dry": "node scripts/_run-with-env.js scripts/editorial-24h.js --dry-run",
    "24h:now": "node scripts/_run-with-env.js scripts/editorial-24h.js --run-now"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "marked": "^17.0.5",
    "sharp": "^0.33.0"
  },
  "notes": {
    "sharp": "이미지 리사이즈·WebP 변환·워터마크 처리용. npm install 후 사용 가능."
  },
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
