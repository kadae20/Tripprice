# Claude Code 로컬 설정 (개인 권한 설정, 커밋 불필요)
.claude/settings.local.json

# 의존성
node_modules/

# 환경변수 / 인증정보 (절대 커밋 금지)
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
service-account.json

# 로그
*.log
npm-debug.log*

# 운영 상태 파일 (대량/민감)
state/coverage/
state/campaigns/*-published.json
state/campaigns/ingest-report-*.md
state/campaigns/seo-qa-*.json
state/campaigns/seo-qa-*.md
state/campaigns/image-report-*.md

# 원본/처리 이미지 (용량 큼, 서버에서 다운로드 → 서버에서 wp-publish)
assets/raw/
assets/processed/

# 이미지 URL 캐시 + 다운로드 원본 (서버 로컬 전용, git 이동 금지)
cache/

# 호텔 원본 데이터 (개인정보 포함 가능)
# sample-hotels.csv는 스키마 레퍼런스용으로 커밋 허용
data/hotels/*
!data/hotels/sample-hotels.csv
data/processed/

# 자동 생성 콘텐츠 초안 (파이프라인 출력물 — 커밋 불필요)
wordpress/drafts/

# Agoda Partners CSV / 월간 리포트 (재무 데이터, 용량 큼)
downloads/

# Newsroom 일일 실행 로그 (자동 생성, 용량 큼)
state/newsroom-log-*.json

# OS / 에디터
.DS_Store
Thumbs.db
.idea/
.vscode/
