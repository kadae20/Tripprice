WP_USER=parkgunho
WP_APP_PASS=isbM ISze Pd1r 2OuN mSpG JZcE

# ── Agoda Content API (이미지 자동 수집용) ────────────
# 파트너 허브(https://partners.agoda.com)에서 발급
# 형식: "{CID}:{secret}" 또는 API 키 단독
# 제약: tripprice.net 서버 도메인에서만 응답 (로컬 불가)
# ── Agoda CID (제휴 링크용) ───────────────────────────
# 기본값 1926938이 이미 하드코딩됨 — 변경 시에만 설정
AGODA_API_KEY=1926938:936bb64d-9a66-49ea-8c45-edf6cd989396
AGODA_CID=1926938

# ── Agoda Affiliate Lite API (이미지/landingURL 폴백) ─
# Content API 권한 없을 때 자동 폴백. 동일 키 재사용.
# Endpoint: http://affiliateapi7643.agoda.com/affiliateservice/lt_v1
# (AGODA_API_KEY 위와 동일 — 별도 설정 불필요)


# ── Subset 추출 조건 (hoteldata-extract.js) ───────────
# HOTELDATA_CITIES=seoul,busan,jeju   # 추출 도시 (쉼표 구분)
# HOTELDATA_EXTRACT_ROWS=50000        # 최대 행 수
# HOTELDATA_EXTRACT_HOTELS=10000      # 최대 유니크 호텔 수
# HOTELDATA_PROGRESS_EVERY=100000     # 진행 로그 간격

# ── 사이트 URL (hreflang / canonical 생성용) ─────────
