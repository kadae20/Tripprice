# ─────────────────────────────────────────────────────────────────
# Tripprice 환경변수 템플릿
# 사용법: 이 파일을 .env.local로 복사 후 실제 값을 채우세요.
#   cp .env.example .env.local
#
# 규칙:
#   - .env.local은 절대 git에 커밋하지 마세요 (.gitignore 포함됨)
#   - API 키는 이 파일에도 실제 값 입력 금지 (예시 형식만)
#   - 운영 서버에서는 시스템 환경변수 또는 secrets manager 사용 권장
# ─────────────────────────────────────────────────────────────────

# ── WordPress ─────────────────────────────────────────────────────
# WordPress 사이트 URL (트레일링 슬래시 없이)
WP_URL=https://tripprice.net

# WordPress 사용자명
WP_USER=your_wp_username

# WordPress Application Password
# 생성: WP 관리자 → 사용자 → 프로필 → Application Passwords
# 형식: 공백 포함 그대로 (예: "NpvM jY16 ZZJm Zdc9 N3Hx H3GI")
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Agoda ─────────────────────────────────────────────────────────
# 아고다 파트너 CID (파트너 허브 → 사이트 ID)
AGODA_CID=1926938

# 아고다 Content API 키 (파트너 허브 → API 키 섹션)
# 형식: CID:secret-key
# ⚠️  Content API는 등록된 서버 도메인에서만 호출 가능 (로컬 CLI 불가)
# ⚠️  이 파일에 실제 키 값을 절대 입력하지 마세요
AGODA_API_KEY=1926938:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── 사이트 URL ────────────────────────────────────────────────────
# 발행될 사이트 기본 URL (canonical URL 생성에 사용)
SITE_URL=https://tripprice.net

# ── Google Search Console (선택) ──────────────────────────────────
# performance-fetch.js 사용 시 필요
GOOGLE_SC_CREDENTIALS=path/to/service-account.json
GOOGLE_SC_SITE_URL=https://tripprice.net/
