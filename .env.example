# ──────────────────────────────────────────────────────
# Tripprice 환경변수 템플릿
# 복사: cp .env.example .env.local
# 주의: .env.local은 절대 커밋하지 마세요 (.gitignore 포함)
# ──────────────────────────────────────────────────────

# ── WordPress (발행용) ────────────────────────────────
# WP 관리자 → 사용자 → 프로필 → Application Passwords에서 생성
WP_URL=https://tripprice.net
WP_USER=admin
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Agoda Content API (이미지 자동 수집용) ────────────
# 파트너 허브(https://partners.agoda.com)에서 발급
# 형식: "{CID}:{secret}" 또는 API 키 단독
# 제약: tripprice.net 서버 도메인에서만 응답 (로컬 불가)
AGODA_API_KEY=1926938:your-api-secret-here

# ── Agoda CID (제휴 링크용) ───────────────────────────
# 기본값 1926938이 이미 하드코딩됨 — 변경 시에만 설정
AGODA_CID=1926938

# ── Agoda Affiliate Lite API (이미지/landingURL 폴백) ─
# Content API 권한 없을 때 자동 폴백. 동일 키 재사용.
# Endpoint: http://affiliateapi7643.agoda.com/affiliateservice/lt_v1
# (AGODA_API_KEY 위와 동일 — 별도 설정 불필요)

# ── Agoda 숙소 데이터 파일 (주 1회 자동 갱신) ────────
# partners.agoda.com → Tools → Hotel Data → 다운로드 버튼 우클릭 → 링크 복사
# 설정 후: npm run hoteldata:sync
AGODA_HOTELDATA_URL=
# HOTELDATA_KEEP=1                    # 주차 폴더 보관 수 (기본 1 = latest만)
# HOTELDATA_SKIP_EXTRACT=true         # extract 생략 (latest.csv만 갱신)
# HOTELDATA_SKIP_INGEST=true          # ingest 생략 (extract까지만 실행)

# ── Subset 추출 조건 (hoteldata-extract.js) ───────────
# HOTELDATA_CITIES=seoul,busan,jeju   # 추출 도시 (쉼표 구분)
# HOTELDATA_EXTRACT_ROWS=50000        # 최대 행 수
# HOTELDATA_EXTRACT_HOTELS=10000      # 최대 유니크 호텔 수
# HOTELDATA_PROGRESS_EVERY=100000     # 진행 로그 간격

# ── 사이트 URL (hreflang / canonical 생성용) ─────────
SITE_URL=https://tripprice.net

# ── Z.ai (ZhipuAI) — AI 초안 생성용 ──────────────────
# https://open.bigmodel.cn 에서 발급
ZAI_API_KEY=your-zhipuai-api-key-here
ZAI_MODEL=glm-4-flash
ZAI_MAX_OUTPUT_TOKENS=2500
# ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4  # 기본값, 변경 불필요

# ── Agoda Partners (월간 KPI CSV 다운로드) ────────────
# partners.agoda.com 로그인 자격증명 (2FA 미사용 계정)
AGODA_PARTNER_EMAIL=your-agoda-partner-email@example.com
AGODA_PARTNER_PASSWORD=your-agoda-partner-password

# ── Notion (월간 KPI 대시보드) ────────────────────────
# https://www.notion.so/my-integrations 에서 Integration 생성 후 DB 공유
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram (알림 봇) ────────────────────────────────
# @BotFather 로 봇 생성 → TOKEN 발급
# 채널/그룹에 봇 추가 후 CHAT_ID 확인: https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── Supabase (작업 상태 저장 — 선택) ─────────────────
# https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 서버 운영 비용 (KPI 순이익 계산용) ───────────────
SERVER_COST_MONTHLY_KRW=20000

# ── 작업 스케줄러 (scheduler-generate-jobs.js) ────────
# 하루 생성할 신규 작업 수 (기본 5, 최대 50)
DAILY_JOB_COUNT=5
# 후보 풀 상한 — 이 수만큼만 CSV를 읽고 중단 (OOM 방지, 기본 20000)
SCHED_CANDIDATE_POOL=20000

# ── 작업 로테이션 (rotation.js) ───────────────────────
# 같은 호텔/조합을 재선정하기까지 대기 일수 (0=비활성)
JOB_COOLDOWN_DAYS=14

# ── 발행 후 스모크 체크 (smoke-check-post.js) ─────────
# 0.0(건너뜀) ~ 1.0(항상 실행). 기본 1.0.
SMOKE_CHECK_SAMPLE_RATE=1.0

# ── WP slug 중복 사전 확인 (wp-publish.js) ────────────
# 1로 설정하면 업로드 직전 slug 사용 여부를 WP REST API로 확인.
# 중복이면 -{baseSlug}-a1, -a2 ... 로 자동 변경.
# WP_SLUG_CHECK=1
