# ──────────────────────────────────────────────────────
# Tripprice 환경변수 템플릿
# 복사: cp .env.example .env.local
# 주의: .env.local은 절대 커밋하지 마세요 (.gitignore 포함)
# ──────────────────────────────────────────────────────

# ── WordPress (발행용) ────────────────────────────────
# WP 관리자 → 사용자 → 프로필 → Application Passwords에서 생성
WP_URL=https://tripprice.net
WP_USER=admin
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Agoda Content API (이미지 자동 수집용) ────────────
# 파트너 허브(https://partners.agoda.com)에서 발급
# 형식: "{CID}:{secret}" 또는 API 키 단독
# 제약: tripprice.net 서버 도메인에서만 응답 (로컬 불가)
AGODA_API_KEY=1926938:your-api-secret-here

# ── Agoda CID (제휴 링크용) ───────────────────────────
# 기본값 1926938이 이미 하드코딩됨 — 변경 시에만 설정
AGODA_CID=1926938

# ── 사이트 URL (hreflang / canonical 생성용) ─────────
SITE_URL=https://tripprice.net

# ── Z.ai (ZhipuAI) — AI 초안 생성용 ──────────────────
# https://open.bigmodel.cn 에서 발급
ZAI_API_KEY=your-zhipuai-api-key-here
ZAI_MODEL=glm-4.7-flashx
ZAI_MAX_OUTPUT_TOKENS=2500
# ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4  # 기본값, 변경 불필요

# ── Agoda Partners (월간 KPI CSV 다운로드) ────────────
# partners.agoda.com 로그인 자격증명 (2FA 미사용 계정)
AGODA_PARTNER_EMAIL=your-agoda-partner-email@example.com
AGODA_PARTNER_PASSWORD=your-agoda-partner-password

# ── Notion (월간 KPI 대시보드) ────────────────────────
# https://www.notion.so/my-integrations 에서 Integration 생성 후 DB 공유
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram (알림 봇) ────────────────────────────────
# @BotFather 로 봇 생성 → TOKEN 발급
# 채널/그룹에 봇 추가 후 CHAT_ID 확인: https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── Supabase (작업 상태 저장 — 선택) ─────────────────
# https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── 서버 운영 비용 (KPI 순이익 계산용) ───────────────
SERVER_COST_MONTHLY_KRW=20000
