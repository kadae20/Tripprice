{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tripprice WP Post Schema",
  "description": "WordPress Draft 발행 시 사용하는 필드 스키마",
  "type": "object",
  "required": ["post_title", "slug", "post_status", "lang"],
  "properties": {
    "post_title": {
      "type": "string",
      "maxLength": 60,
      "description": "SEO title. 60자 이하, 핵심 키워드 포함"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "소문자 하이픈 구분, 3~5단어"
    },
    "post_status": {
      "type": "string",
      "enum": ["draft"],
      "description": "항상 draft. publish는 사람이 직접 수행"
    },
    "post_content": {
      "type": "string",
      "description": "HTML 변환된 본문"
    },
    "post_excerpt": {
      "type": "string",
      "maxLength": 200,
      "description": "2~3문장 요약. 누구를 위한 글인지 + 핵심 가치"
    },
    "meta": {
      "type": "object",
      "properties": {
        "meta_description": {
          "type": "string",
          "minLength": 120,
          "maxLength": 155,
          "description": "검색 결과 설명. 독자 타겟 + 가치 + 행동 유도"
        },
        "canonical_url": {
          "type": "string",
          "format": "uri",
          "description": "자기 자신 URL. 다국어 버전도 각자 자신을 가리킴"
        }
      }
    },
    "lang": {
      "type": "string",
      "enum": ["ko", "en", "ja"],
      "description": "글 언어"
    },
    "hreflang_links": {
      "type": "array",
      "description": "다국어 버전 연결",
      "items": {
        "type": "object",
        "required": ["lang", "url"],
        "properties": {
          "lang": { "type": "string", "enum": ["ko", "en", "ja", "x-default"] },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "featured_media": {
      "type": "integer",
      "description": "WordPress 미디어 라이브러리 이미지 ID"
    },
    "categories": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "WP 카테고리 ID 배열"
    },
    "tags": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "WP 태그 ID 배열"
    },
    "affiliate_links": {
      "type": "array",
      "description": "삽입된 제휴 링크 목록 (추적/관리용)",
      "items": {
        "type": "object",
        "required": ["hotel_id", "url"],
        "properties": {
          "hotel_id": { "type": "string" },
          "hotel_name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "utm_source": { "type": "string", "default": "tripprice" },
          "position": {
            "type": "string",
            "enum": ["hotel-section", "comparison", "footer"],
            "description": "링크 삽입 위치"
          }
        }
      }
    },
    "coverage_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "글에 등장하는 주요 호텔의 평균 data_coverage_score"
    },
    "schema_markup": {
      "type": "object",
      "description": "구조화 데이터 (Article / FAQPage / Hotel 등). JSON-LD 형식",
      "properties": {
        "type": { "type": "string", "enum": ["Article", "FAQPage", "Hotel", "BreadcrumbList"] },
        "data": { "type": "object" }
      }
    },
    "data_notice": {
      "type": "string",
      "default": "가격·혜택·환불 규정은 시기에 따라 변동될 수 있으며, 최종 조건은 예약 페이지에서 직접 확인하시기 바랍니다.",
      "description": "가격 고지 문구. 모든 글 필수 포함"
    },
    "affiliate_notice": {
      "type": "string",
      "default": "이 글에는 아고다 파트너 링크가 포함되어 있습니다. 링크를 통해 예약하시면 추가 비용 없이 운영에 도움이 됩니다.",
      "description": "제휴 고지 문구. 제휴 링크 포함 글 필수"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "Draft 발행 시각 (ISO 8601)"
    },
    "workflow_state": {
      "type": "object",
      "description": "편집국 워크플로우 단계 완료 기록",
      "properties": {
        "plan": { "type": "boolean", "default": false },
        "brief": { "type": "boolean", "default": false },
        "draft": { "type": "boolean", "default": false },
        "fact_check": { "type": "boolean", "default": false },
        "seo_qa": { "type": "boolean", "default": false },
        "humanize": { "type": "boolean", "default": false },
        "cta": { "type": "boolean", "default": false },
        "internal_links": { "type": "boolean", "default": false },
        "wp_draft": { "type": "boolean", "default": false },
        "human_review": { "type": "boolean", "default": false }
      }
    }
  }
}
